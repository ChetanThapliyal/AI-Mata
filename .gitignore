# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Environment / secrets — NEVER commit these
.env
.env.*
!.env.example

# Private keys & certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Logs
*.log
logs/

# OS artifacts
.DS_Store
Thumbs.db

# IDE / editor directories
.vscode/
.idea/
*.swp

# Terraform state
*.tfstate
*.tfstate.*
*.tfvars

# Android — never commit local config or generated files
android-app/local.properties
android-app/.gradle/
android-app/app/build/
android-app/build/
android-app/**/*.apk
android-app/**/*.aab
